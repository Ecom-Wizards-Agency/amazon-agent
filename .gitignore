.DS_Store

# Local visual builds and heavy assets
.final-build/
assets/
*.zip

# Local outputs and evidence
Output/
review-tracking/
Downloads/
screenshots/
Screenshots/

# Local user preferences and standing permissions
!_local/
_local/*
!_local/.gitkeep

# Keep base artifact folders in GitHub, but ignore their contents.
!output/
output/*
!output/.gitkeep
!evidence/
evidence/*
!evidence/.gitkeep
!downloads/
downloads/*
!downloads/.gitkeep
!_local-output/
_local-output/*
!_local-output/.gitkeep

# Temporary files
*.tmp
*.temp
*.bak
*.swp
~$*
