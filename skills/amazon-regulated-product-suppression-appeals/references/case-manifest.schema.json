{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Regulated Product Suppression Appeal Case",
  "type": "object",
  "required": [
    "client_slug",
    "case_slug",
    "case_date",
    "marketplace",
    "issue_type",
    "status",
    "affected_products",
    "claims",
    "consistency_checks",
    "catalog_correction",
    "victor_signoff",
    "modules"
  ],
  "properties": {
    "client_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "case_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "case_date": {"type": "string", "format": "date"},
    "marketplace": {"type": "string", "minLength": 1},
    "issue_type": {
      "enum": [
        "supplement",
        "cosmetic_or_serum",
        "otc_or_drug_classification",
        "device_or_application_tool",
        "restricted_product",
        "packaging_or_labeling",
        "unsupported_claims",
        "other"
      ]
    },
    "status": {
      "enum": [
        "Draft",
        "Evidence incomplete",
        "Senior review ready",
        "Victor signoff required",
        "Approved for manual submission"
      ]
    },
    "affected_products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["asin", "skus"],
        "properties": {
          "asin": {"type": "string", "minLength": 1},
          "skus": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "variation_value": {"type": "string"},
          "product_identifier": {"type": "string"}
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "material", "evidence", "verified"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "material": {"type": "boolean"},
          "evidence": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "verified": {"type": "boolean"}
        }
      }
    },
    "consistency_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subject", "status", "evidence"],
        "properties": {
          "subject": {"type": "string", "minLength": 1},
          "status": {
            "enum": ["consistent", "conflict", "not_reviewed", "not_applicable"]
          },
          "evidence": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "catalog_correction": {
      "type": "object",
      "required": ["status", "submitted_skus"],
      "properties": {
        "status": {
          "enum": ["not_required", "prepared", "uploaded", "processed", "verified"]
        },
        "submitted_skus": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "processing_summary": {"type": ["string", "null"]},
        "post_update_verification": {"type": ["string", "null"]}
      }
    },
    "victor_signoff": {
      "type": "object",
      "required": ["approved"],
      "properties": {
        "approved": {"type": "boolean"},
        "approved_at": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["required", "files"],
        "properties": {
          "required": {"type": "boolean"},
          "files": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    }
  }
}
